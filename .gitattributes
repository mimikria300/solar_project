# Normalize line endings to LF in the repo for everyone
* text=auto

# Explicitly LF for code and web assets
*.py    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf

# Binary assets — never touch line endings
*.ttf   binary
*.woff  binary
*.woff2 binary
*.eot   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.zip   binary
